NODE_ENV=production
PORT=3000
PUBLIC_ORIGIN=https://example.com
ADMIN_ORIGIN=https://admin.example.com
PUBLIC_HOSTNAMES=example.com
ADMIN_HOSTNAMES=admin.example.com
SOURCE_ROOT=/opt/adaptive-test-source
DB_PATH=/var/lib/adaptive-test/app.sqlite
PRACTICE_BANK_ROOT=/opt/adaptive-test-source/practice-bank
EXAM_ENABLED=false
SESSION_SECRET=replace-with-long-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password
ADMIN_TOTP_SECRET=replace-with-base32-secret
DEFAULT_NICKNAME=逍遥雀士
NICKNAME_REVIEW_MAX_FAILURES=2
NICKNAME_RATE_LIMIT_PER_MINUTE=5
USER_ME_RATE_LIMIT_PER_MINUTE=120
LEADERBOARD_RATE_LIMIT_PER_MINUTE=120
ATTEMPT_START_RATE_LIMIT_PER_MINUTE=20
ATTEMPT_WRITE_RATE_LIMIT_PER_MINUTE=180
ASSET_RATE_LIMIT_PER_MINUTE=240
IDENTITY_CREATE_RATE_LIMIT_PER_HOUR=120
GLOBAL_RATE_LIMIT_PER_MINUTE=5000
RATE_LIMIT_SCOPE_MULTIPLIER=20
CLUSTER_REBUILD_MAX_PAIRS=100000
CLUSTER_REBUILD_MAX_MS=5000
CLUSTER_REBUILD_MAX_RETRIES=3
ADMIN_LOGIN_ACCOUNT_FAILURE_LIMIT=30
ADMIN_LOGIN_ACCOUNT_WINDOW_MINUTES=15
TENCENTCLOUD_SECRET_ID=replace-with-tencent-secret-id
TENCENTCLOUD_SECRET_KEY=replace-with-tencent-secret-key
TENCENT_TMS_REGION=ap-guangzhou
TENCENT_TMS_BIZ_TYPE=nickname_input
TENCENT_TMS_ENDPOINT=tms.tencentcloudapi.com
TENCENT_TMS_TIMEOUT_MS=3000
