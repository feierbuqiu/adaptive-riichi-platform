# Public repository allowlist. Everything at the workspace root is private
# unless it is explicitly included below.
/*

!/.gitignore
!/.gitattributes
!/LICENSE
!/README.md
!/ROADMAP.md
!/.github/
!/app/
!/deploy/
!/assets/
!/examples/
!/docs/

# Runtime and local-development state must never be published.
/app/.env
/app/.env.*
!/app/.env.example
/app/data/
/app/node_modules/
/app/*.log

# Only public deployment templates are tracked.
/deploy/*
!/deploy/Caddyfile.example
!/deploy/docker-compose.example.yml
!/deploy/README.md

# Defense in depth for secrets and generated artifacts at any depth.
**/secrets/
**/.env
**/*.pem
**/*.key
**/*.p12
**/*.pfx
**/*.sqlite
**/*.sqlite3
**/*.db
**/*.db-wal
**/*.db-shm
**/*.tgz
**/*.zip
**/*.log
**/node_modules/
